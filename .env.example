# -----------------------------------------------------------------------------
# GECO2 runtime defaults (loaded by docker-compose.yml via env_file)
# Copy to .env and adjust as needed.
# -----------------------------------------------------------------------------

# PNG compression level for response_format=png (0=fastest, 9=smallest)
PNG_COMPRESS_LEVEL=1

# Default response format for */image endpoints: png|jpeg|webp
DEFAULT_IMAGE_FORMAT=jpeg

# Default output image max side in pixels for */image endpoints (0 disables resize)
DEFAULT_IMAGE_MAX_SIDE=1280

# Default quality for JPEG/WEBP (1-100)
DEFAULT_IMAGE_QUALITY=85
